# === DATABASE ===
DB_HOST=localhost
DB_PORT=5432
DB_USER=kazdispatch
DB_PASSWORD=SecurePassword123!
DB_NAME=kazdispatch_db

# === REDIS ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=RedisPass123!

# === MinIO/S3 ===
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123!
MINIO_BUCKET_DRIVERS=driver-photos
MINIO_BUCKET_VEHICLES=vehicle-photos
MINIO_BUCKET_CARGO=cargo-photos
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_SIGNATURES=signatures

# === JWT ===
JWT_SECRET=your-super-secret-jwt-key-change-in-production-now-now
JWT_EXPIRATION=900
JWT_REFRESH_EXPIRATION=2592000

# === SMS PROVIDERS ===
SMS_PROVIDER=beeline
BEELINE_API_KEY=your_beeline_api_key_here
KCELL_API_KEY=your_kcell_api_key_here

# === BACKEND ===
NODE_ENV=development
BACKEND_PORT=3000
BACKEND_URL=http://localhost:3000

# === FRONTEND ===
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000/api
VITE_YANDEX_MAP_API_KEY=your_yandex_maps_api_key_here

# === TIMEZONE ===
TZ=Asia/Almaty

# === ENVIRONMENT ===
NODE_ENV=development
