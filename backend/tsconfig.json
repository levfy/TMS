{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "lib": ["ES2021"],
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@/*": ["*"],
      "@auth/*": ["auth/*"],
      "@users/*": ["users/*"],
      "@companies/*": ["companies/*"],
      "@drivers/*": ["drivers/*"],
      "@vehicles/*": ["vehicles/*"],
      "@orders/*": ["orders/*"],
      "@uploads/*": ["uploads/*"],
      "@notifications/*": ["notifications/*"],
      "@reports/*": ["reports/*"],
      "@common/*": ["common/*"],
      "@database/*": ["database/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test", "**/*spec.ts"]
}
